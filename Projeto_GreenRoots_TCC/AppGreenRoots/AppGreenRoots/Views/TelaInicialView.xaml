<UserControl x:Class="AppGreenRoots.Views.TelaInicialView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             Width="900"
             Height="560">

    <UserControl.Resources>
        <SolidColorBrush x:Key="BgDark"   Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BgCard"   Color="#126b40"/>
        <SolidColorBrush x:Key="Green"    Color="#FFFFFF"/>
        <SolidColorBrush x:Key="White"    Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextMuted" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BorderClr" Color="#2A5038"/>

        
        <Style x:Key="BtnSair" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#FFFFFF"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="Height"          Value="30"/>
            <Setter Property="Width"           Value="70"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="6"
                                BorderBrush="#FFFFFF" BorderThickness="1"
                                Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Green}"/>
                                <Setter Property="Foreground" Value="{StaticResource Green}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    
    <Style x:Key="BtnPrincipais" TargetType="Button">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="Foreground"      Value="#FFFFFF"/>
        <Setter Property="FontSize"        Value="12"/>
        <Setter Property="FontFamily"      Value="Segoe UI"/>
        <Setter Property="Height"          Value="30"/>
        <Setter Property="Width"           Value="70"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" CornerRadius="6"
                            BorderBrush="#525C5A" BorderThickness="1"
                            Background="#522828">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Green}"/>
                            <Setter Property="Foreground" Value="{StaticResource Green}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    </UserControl.Resources>

    <Border CornerRadius="12" Background="{StaticResource BgDark}">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Color="#000000" Opacity="0.5"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Barra superior -->
            <Border Grid.Row="0" Background="{StaticResource BgCard}"
                    CornerRadius="12,12,0,0"
                    BorderBrush="{StaticResource BorderClr}" BorderThickness="0,0,0,1">
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="AppGreenRoots"
                               FontSize="14" FontWeight="Bold" FontFamily="Segoe UI"
                               Foreground="{StaticResource Green}"
                               VerticalAlignment="Center"/>

                    <TextBlock Grid.Column="1" FontSize="13" FontFamily="Segoe UI"
                               Foreground="{StaticResource TextMuted}"
                               HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Run Text="Bem-vindo, "/>
                        <Run Text="{Binding NomeUsuario}"
                             Foreground="{StaticResource White}" FontWeight="SemiBold"/>
                    </TextBlock>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="Sair" Style="{StaticResource BtnSair}"
                                Command="{Binding LogoutCommand}" Margin="0,0,8,0"/>
                        <Button Content="✕" Width="24" Height="24" FontSize="11"
                                Foreground="{StaticResource TextMuted}" Background="Transparent"
                                BorderThickness="0" Cursor="Hand"
                                Command="{Binding ExitCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Conteúdo -->
            <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                
                <Button Content="Gerar Passaporte (PDF)"
                        Style="{StaticResource BtnPrincipais}"
                        Width="240" Height="44"
                        Command="{Binding AbrirPassaporteCommand}"
                        Cursor="Hand"/>
            </StackPanel>

        </Grid>
    </Border>
</UserControl>