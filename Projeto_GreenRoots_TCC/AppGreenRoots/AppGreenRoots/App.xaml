<Application x:Class="AppGreenRoots.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AppGreenRoots.ViewModels"
             xmlns:views="clr-namespace:AppGreenRoots.Views"
             StartupUri="Views/ShellWindow.xaml">

    <Application.Resources>

        <DataTemplate DataType="{x:Type vm:LoginViewModel}">
            <views:LoginView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:PassaporteWizardViewModel}">
            <views:PassaporteWizardView/>
        </DataTemplate>

    </Application.Resources>

</Application>